HOST=0.0.0.0
PORT=1337
APP_KEYS="toBeModified1,toBeModified2"
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified
JWT_SECRET=tobemodified
ENCRYPTION_KEY=tobemodified

# Database
DATABASE_URL=postgres://promocean:promocean@localhost:5433/promocean

# Promocean config-plane
CONFIG_PLANE_SECRET=dev-config-secret
SEED_DEMO=true
LOG_PLAINTEXT_KEYS=true

# auto-seeds the Strapi super-admin when no admin exists
ADMIN_FIRST_NAME=changeme
ADMIN_LAST_NAME=changeme
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme

# reserved for future users-permissions test account (unused)
USER_FIRST_NAME=changeme
USER_LAST_NAME=changeme
USER_USERNAME=changeme
USER_EMAIL=user@example.com
USER_PASSWORD=changeme
