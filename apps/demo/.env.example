NEXT_PUBLIC_PROMOCEAN_KEY=pk_test_demo_1234567890abcdef
NEXT_PUBLIC_PROMOCEAN_API=http://localhost:3001

# Server-only: read by app/stats/page.tsx (a server component) to call the
# secret-key-only GET /v1/stats endpoint. This must NEVER be prefixed with
# NEXT_PUBLIC_ — that prefix ships a variable's value into the browser
# bundle, and a leaked secret key grants stats/erasure access.
PROMOCEAN_SECRET_KEY=sk_test_demo_1234567890abcdef

# Optional: server-side override for the API base URL used by /stats. Falls
# back to NEXT_PUBLIC_PROMOCEAN_API when unset (that value isn't sensitive —
# it's just a hostname — so reusing it server-side is fine).
# PROMOCEAN_API_URL=http://localhost:3001
